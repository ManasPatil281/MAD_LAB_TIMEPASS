<?xml version="1.0" encoding="utf-8"?>
<!--
Plagiarism Detection Screen - ScholarHub
Integrity scanner with donut chart, matched sources, and editorial styling
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    tools:context=".PlagiarismDetectionActivity">

    <!-- TopAppBar - Frosted Glass -->
    <FrameLayout
        android:id="@+id/toolbar_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:elevation="2dp"
        android:background="@color/surface_container_lowest">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/toolbar_height"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/padding_medium"
                android:paddingEnd="@dimen/padding_medium">

                <ImageView
                    android:layout_width="@dimen/icon_small"
                    android:layout_height="@dimen/icon_small"
                    android:src="@drawable/ic_review"
                    android:tint="@color/primary_container"
                    android:layout_marginEnd="@dimen/margin_small" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ScholarHub"
                    android:textSize="20sp"
                    android:textStyle="bold|italic"
                    android:textColor="@color/primary_container"
                    android:fontFamily="serif" />

                <ImageView
                    android:layout_width="@dimen/icon_small"
                    android:layout_height="@dimen/icon_small"
                    android:src="@drawable/ic_users"
                    android:tint="@color/primary_container" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/surface_container_high" />

        </LinearLayout>
    </FrameLayout>

    <!-- Hidden toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:navigationIcon="@drawable/ic_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/toolbar_container"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_medium"
            android:paddingBottom="100dp">

            <!-- Editorial Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/margin_large">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="QUALITY ASSESSMENT"
                    style="@style/Text.Label.Upper"
                    android:textColor="@color/primary"
                    android:layout_marginBottom="@dimen/margin_small" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Plagiarism Detection"
                    android:textSize="@dimen/text_size_headline"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:fontFamily="serif"
                    android:layout_marginBottom="@dimen/margin_small" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Comprehensive integrity analysis for your research manuscripts."
                    android:textSize="@dimen/text_size_medium"
                    android:textColor="@color/on_surface_variant"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

            <!-- Initial State -->
            <LinearLayout
                android:id="@+id/ll_initial_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:gravity="center"
                android:padding="@dimen/padding_large">

                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@drawable/ic_plagiarism_check"
                    android:alpha="0.6" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ready to Check for Plagiarism"
                    android:textSize="@dimen/text_size_large"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:fontFamily="serif"
                    android:layout_marginTop="@dimen/margin_medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upload your research paper to scan for potential plagiarism against billions of sources."
                    android:textAlignment="center"
                    android:textColor="@color/on_surface_variant"
                    android:layout_marginTop="@dimen/margin_small"/>

                <Button
                    android:id="@+id/btn_upload_paper_initial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upload Research Paper (PDF)"
                    android:layout_marginTop="@dimen/margin_large"
                    style="@style/Button.Primary"/>

                <include
                    android:id="@+id/model_selector"
                    layout="@layout/layout_model_selector"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_medium" />
            </LinearLayout>

            <!-- Scanning Progress -->
            <LinearLayout
                android:id="@+id/ll_scanning_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/padding_large"
                android:visibility="gone">

                <ProgressBar
                    android:layout_width="64dp"
                    android:layout_height="64dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scanning for Plagiarism..."
                    android:textSize="@dimen/text_size_large"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:fontFamily="serif"
                    android:layout_marginTop="@dimen/margin_medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="This may take a few moments."
                    android:textAlignment="center"
                    android:textColor="@color/on_surface_variant"
                    android:layout_marginTop="@dimen/margin_small"/>
            </LinearLayout>

            <!-- Results Section -->
            <LinearLayout
                android:id="@+id/ll_results"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Similarity Score Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/surface_container_lowest"
                    app:strokeColor="@color/outline_variant"
                    app:strokeWidth="0.5dp"
                    android:layout_marginBottom="@dimen/margin_medium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/padding_large">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="@dimen/margin_medium">

                            <!-- Score -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_overall_similarity"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="8%"
                                    android:textSize="48sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/primary"
                                    android:fontFamily="serif" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="SIMILARITY"
                                    style="@style/Text.Label.Upper"
                                    android:textColor="@color/outline" />

                            </LinearLayout>

                            <!-- Badge -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="end">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:background="@drawable/bg_tip_box"
                                    android:paddingStart="12dp"
                                    android:paddingEnd="12dp"
                                    android:paddingTop="6dp"
                                    android:paddingBottom="6dp"
                                    android:layout_marginBottom="@dimen/margin_small">

                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="16dp"
                                        android:src="@drawable/ic_check_circle"
                                        android:tint="@color/secondary"
                                        android:layout_marginEnd="6dp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="LOW RISK"
                                        android:textSize="@dimen/text_size_tiny"
                                        android:textStyle="bold"
                                        android:textAllCaps="true"
                                        android:letterSpacing="0.1"
                                        android:textColor="@color/secondary" />

                                </LinearLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Within academic thresholds"
                                    android:textSize="@dimen/text_size_small"
                                    android:textColor="@color/on_surface_variant" />

                            </LinearLayout>

                        </LinearLayout>

                        <!-- Progress Bar -->
                        <ProgressBar
                            android:id="@+id/progress_overall_similarity"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="12dp"
                            android:max="100"
                            android:progress="8"
                            android:progressDrawable="@drawable/progress_plagiarism" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Matched Sources Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MATCHED SOURCES"
                    style="@style/Text.Label.Upper"
                    android:layout_marginBottom="@dimen/margin_medium"
                    android:layout_marginStart="4dp"/>

                <!-- Matched Sources List -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_matched_sources"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:itemCount="4"
                    tools:listitem="@layout/item_plagiarism_source"/>

                <Button
                    android:id="@+id/btn_view_report"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="View Detailed Report"
                    style="@style/Button.Primary" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
