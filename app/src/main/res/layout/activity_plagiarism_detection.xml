<?xml version="1.0" encoding="utf-8"?>
<!--
Plagiarism Detection Screen - ScholarMate
Displays plagiarism analysis results, including a similarity score and a list of matched sources.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_secondary"
    tools:context=".PlagiarismDetectionActivity">

    <!-- App Bar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        android:elevation="4dp"
        app:title="Plagiarism Detection"
        app:titleTextColor="@color/white"
        app:navigationIcon="@drawable/ic_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_medium">

            <!-- Initial State / Upload Section -->
            <LinearLayout
                android:id="@+id/ll_initial_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:gravity="center"
                android:padding="@dimen/padding_large">

                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@drawable/ic_plagiarism_check"
                    android:alpha="0.6" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ready to Check for Plagiarism"
                    android:textSize="@dimen/text_size_large"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="@dimen/margin_medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upload your research paper to scan for potential plagiarism against billions of sources."
                    android:textAlignment="center"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="@dimen/margin_small"/>

                <Button
                    android:id="@+id/btn_upload_paper_initial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upload Research Paper (PDF)"
                    android:layout_marginTop="@dimen/margin_large"
                    style="@style/Button.Primary"/>
            </LinearLayout>

            <!-- Scanning Progress -->
            <LinearLayout
                android:id="@+id/ll_scanning_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/padding_large"
                android:visibility="gone">

                <ProgressBar
                    android:layout_width="64dp"
                    android:layout_height="64dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scanning for Plagiarism..."
                    android:textSize="@dimen/text_size_large"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="@dimen/margin_medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="This may take a few moments. We are comparing your document against our extensive database."
                    android:textAlignment="center"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="@dimen/margin_small"/>
            </LinearLayout>


            <!-- Results Section -->
            <LinearLayout
                android:id="@+id/ll_results_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- Summary Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation"
                    android:layout_marginBottom="@dimen/margin_large">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/padding_large">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Plagiarism Report"
                            android:textSize="@dimen/text_size_xlarge"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="@dimen/margin_medium"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ProgressBar
                                android:id="@+id/progress_overall_similarity"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="0dp"
                                android:layout_height="12dp"
                                android:layout_weight="1"
                                android:max="100"
                                android:progress="28"
                                android:progressDrawable="@drawable/progress_plagiarism"
                                android:layout_marginEnd="@dimen/margin_medium"/>

                            <TextView
                                android:id="@+id/tv_overall_similarity"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="28% Overall Similarity"
                                android:textSize="@dimen/text_size_large"
                                android:textStyle="bold"
                                android:textColor="@color/plagiarism_color"/>

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Based on a comparison with 4 matched sources."
                            android:textSize="@dimen/text_size_small"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="@dimen/margin_small"/>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Matched Sources Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Matched Sources"
                    android:textSize="@dimen/text_size_large"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="@dimen/margin_medium"/>

                <!-- Matched Sources List -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_matched_sources"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:itemCount="4"
                    tools:listitem="@layout/item_plagiarism_source"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
