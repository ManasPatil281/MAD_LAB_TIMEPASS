<?xml version="1.0" encoding="utf-8"?>
<!--
AI Content Detection Screen - ScholarMate
Enhanced UI with confidence visualization and detailed results
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_secondary"
    tools:context=".AiContentDetectionActivity">

    <!-- App Bar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        android:elevation="4dp"
        app:title="AI Content Detection"
        app:titleTextColor="@color/white"
        app:navigationIcon="@drawable/ic_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_medium">

            <!-- Input Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                android:layout_marginBottom="@dimen/margin_medium">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_medium">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Text Input"
                        android:textSize="@dimen/text_size_large"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="@dimen/margin_small" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Enter text or upload a PDF to analyze..."
                        app:boxStrokeColor="@color/primary"
                        app:counterEnabled="true"
                        app:counterMaxLength="10000"
                        app:endIconMode="clear_text"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_text_input"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:gravity="top|start"
                            android:inputType="textMultiLine"
                            android:maxLength="10000"
                            android:minHeight="180dp"
                            android:scrollbars="vertical"
                            android:textSize="@dimen/text_size_medium" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_medium"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_upload_pdf"
                    style="@style/Button.Secondary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/margin_small"
                    android:layout_weight="1"
                    android:drawableStart="@drawable/ic_pdf"
                    android:drawablePadding="@dimen/padding_small"
                    android:text="Upload PDF" />

                <Button
                    android:id="@+id/btn_detect_ai"
                    style="@style/Button.Primary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_small"
                    android:layout_weight="1"
                    android:drawableStart="@drawable/ic_ai_scan"
                    android:drawablePadding="@dimen/padding_small"
                    android:text="Detect AI" />

            </LinearLayout>

            <!-- Analysis Progress -->
            <LinearLayout
                android:id="@+id/ll_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/padding_xlarge"
                android:visibility="gone">

                <ProgressBar
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:indeterminate="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Analyzing content with AI..."
                    android:textSize="@dimen/text_size_medium"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="@dimen/margin_medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="This may take a few moments"
                    android:textSize="@dimen/text_size_small"
                    android:textColor="@color/text_hint"
                    android:layout_marginTop="@dimen/margin_small" />

            </LinearLayout>

            <!-- Results Section -->
            <LinearLayout
                android:id="@+id/ll_results"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- Result Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation"
                    android:layout_marginBottom="@dimen/margin_medium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/padding_large">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Detection Result"
                            android:textSize="@dimen/text_size_large"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="@dimen/margin_medium" />

                        <!-- Result Status with Icon -->

                        <!-- Confidence Score Section -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/margin_medium"
                            android:background="@drawable/bg_result_container"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="@dimen/padding_medium">

                            <ImageView
                                android:id="@+id/iv_result_icon"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_marginEnd="@dimen/margin_medium"
                                android:src="@drawable/ic_ai_positive" />

                            <TextView
                                android:id="@+id/tv_result"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Likely AI-Generated Content"
                                android:textColor="@color/text_primary"
                                android:textSize="@dimen/text_size_large"
                                android:textStyle="bold"
                                tools:ignore="HardcodedText" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Confidence Score"
                            android:textSize="@dimen/text_size_medium"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"
                            android:layout_marginBottom="@dimen/margin_small" />

                        <!-- Circular Progress Indicator -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="@dimen/margin_medium">

                            <ProgressBar
                                android:id="@+id/progress_confidence"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="0dp"
                                android:layout_height="8dp"
                                android:layout_weight="1"
                                android:max="100"
                                android:progress="92"
                                android:progressDrawable="@drawable/progress_gradient"
                                android:layout_marginEnd="@dimen/margin_medium" />

                            <TextView
                                android:id="@+id/tv_confidence_score"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="92%"
                                android:textSize="@dimen/text_size_xlarge"
                                android:textStyle="bold"
                                android:textColor="@color/primary"
                                tools:ignore="HardcodedText" />

                        </LinearLayout>

                        <!-- Detailed Analysis -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Analysis Details"
                            android:textSize="@dimen/text_size_medium"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="@dimen/margin_medium"
                            android:layout_marginBottom="@dimen/margin_small" />

                        <TextView
                            android:id="@+id/tv_analysis_details"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="The analysis indicates a high probability of AI-generated content. The text exhibits unusually consistent sentence length, low perplexity, and a lack of personal or idiomatic expressions. These are strong indicators of machine-generated text."
                            android:textSize="@dimen/text_size_normal"
                            android:textColor="@color/text_primary"
                            android:lineSpacingExtra="4dp"
                            tools:ignore="HardcodedText" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Action Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn_share_results"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Share"
                        android:drawableStart="@drawable/ic_share"
                        android:drawablePadding="@dimen/padding_small"
                        android:layout_marginEnd="@dimen/margin_small"
                        style="@style/Button.Secondary" />

                    <Button
                        android:id="@+id/btn_save_report"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Save Report"
                        android:drawableStart="@drawable/ic_download"
                        android:drawablePadding="@dimen/padding_small"
                        android:layout_marginStart="@dimen/margin_small"
                        style="@style/Button.Primary" />

                </LinearLayout>

            </LinearLayout>

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/ll_empty_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/padding_xlarge"
                android:visibility="gone">

                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@drawable/ic_ai_empty"
                    android:alpha="0.5" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No analysis yet"
                    android:textSize="@dimen/text_size_large"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="@dimen/margin_medium"
                    android:layout_marginBottom="@dimen/margin_small" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enter text or upload a PDF to detect AI-generated content"
                    android:textSize="@dimen/text_size_normal"
                    android:textColor="@color/text_hint"
                    android:textAlignment="center" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
