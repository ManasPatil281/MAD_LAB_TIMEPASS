<?xml version="1.0" encoding="utf-8"?>
<!--
Gesture Playground Screen - ScholarHub
Interactive area with editorial styling
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <!-- TopAppBar - Frosted Glass -->
    <FrameLayout
        android:id="@+id/toolbar_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:elevation="2dp"
        android:background="@color/surface_container_lowest">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/toolbar_height"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/padding_medium"
                android:paddingEnd="@dimen/padding_medium">

                <ImageView
                    android:layout_width="@dimen/icon_small"
                    android:layout_height="@dimen/icon_small"
                    android:src="@drawable/ic_review"
                    android:tint="@color/primary_container"
                    android:layout_marginEnd="@dimen/margin_small" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ScholarHub"
                    android:textSize="20sp"
                    android:textStyle="bold|italic"
                    android:textColor="@color/primary_container"
                    android:fontFamily="serif" />

                <ImageView
                    android:layout_width="@dimen/icon_small"
                    android:layout_height="@dimen/icon_small"
                    android:src="@drawable/ic_users"
                    android:tint="@color/primary_container" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/surface_container_high" />

        </LinearLayout>
    </FrameLayout>

    <!-- Hidden toolbar for navigation -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_gestures"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:navigationIcon="@drawable/ic_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Gesture Status Display -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/margin_medium"
        app:cardCornerRadius="@dimen/card_corner_radius"
        app:cardElevation="@dimen/card_elevation"
        app:cardBackgroundColor="@color/surface_container_lowest"
        app:layout_constraintTop_toBottomOf="@id/toolbar_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_large"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_gesture_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Perform a gesture below!"
                android:textSize="@dimen/text_size_xlarge"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:fontFamily="serif" />

            <TextView
                android:id="@+id/tv_gesture_detail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap, swipe, pinch, or rotate the box"
                android:textSize="@dimen/text_size_normal"
                android:textColor="@color/on_surface_variant"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Touch Area (Gesture Canvas) -->
    <FrameLayout
        android:id="@+id/touch_area"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="@dimen/margin_medium"
        android:background="@drawable/bg_touch_area"
        android:clipChildren="false"
        app:layout_constraintTop_toBottomOf="@id/card_status"
        app:layout_constraintBottom_toTopOf="@id/card_instructions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/gesture_box"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_gesture_box"
            android:elevation="8dp" />

    </FrameLayout>

    <!-- Instructions Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_instructions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/margin_medium"
        app:cardCornerRadius="@dimen/card_corner_radius"
        app:cardElevation="@dimen/card_elevation"
        app:cardBackgroundColor="@color/surface_container_lowest"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_large">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AVAILABLE GESTURES"
                style="@style/Text.Label.Upper"
                android:layout_marginBottom="@dimen/margin_small" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👆 Tap · 👆👆 Double Tap · ✋ Long Press\n⬅️➡️⬆️⬇️ Swipe · 🤏 Pinch Zoom · 🔄 Rotate"
                android:textSize="@dimen/text_size_small"
                android:textColor="@color/on_surface_variant"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
