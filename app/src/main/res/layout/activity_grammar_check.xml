<?xml version="1.0" encoding="utf-8"?>
<!--
Grammar & Style Check Screen - ScholarMate
Enhanced UI with better visual hierarchy and user experience
Features:
- Material Design card for input area
- Character counter
- Language selector
- Clear text button
- Enhanced results display with categories
- Empty state message
- Loading indicator with text
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_secondary"
    tools:context=".GrammarCheckActivity">

    <!-- App Bar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        android:elevation="4dp"
        app:title="Grammar &amp; Style Check"
        app:titleTextColor="@color/white"
        app:navigationIcon="@drawable/ic_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_medium">

            <!-- Input Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/card_background"
                android:layout_marginBottom="@dimen/margin_medium">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_medium">

                    <!-- Section Title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Text Input"
                        android:textSize="@dimen/text_size_large"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="@dimen/margin_small" />

                    <!-- Text Input Area with Material Design -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Enter or paste text to check grammar and style..."
                        app:boxStrokeColor="@color/primary"
                        app:hintTextColor="@color/primary"
                        app:counterEnabled="true"
                        app:counterMaxLength="5000"
                        app:endIconMode="clear_text"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_text_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="200dp"
                            android:maxLength="5000"
                            android:gravity="top|start"
                            android:inputType="textMultiLine|textCapSentences"
                            android:scrollbars="vertical"
                            android:textSize="@dimen/text_size_medium"
                            android:textColor="@color/text_primary"
                            android:text="The quick brown fox jump over the lazy dog. The dog was not amused and choose to ignore the fox."/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Language Selection -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="@dimen/margin_medium">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Language:"
                            android:textSize="@dimen/text_size_medium"
                            android:textColor="@color/text_secondary"
                            android:layout_marginEnd="@dimen/margin_small" />

                        <Spinner
                            android:id="@+id/spinner_language"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:entries="@array/languages"
                            android:spinnerMode="dropdown" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/margin_medium">

                <Button
                    android:id="@+id/btn_upload_file"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Upload File"
                    android:drawableStart="@drawable/ic_upload"
                    android:drawablePadding="@dimen/padding_small"
                    android:layout_marginEnd="@dimen/margin_small"
                    style="@style/Button.Secondary" />

                <Button
                    android:id="@+id/btn_check_grammar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Check Grammar"
                    android:drawableStart="@drawable/ic_check"
                    android:drawablePadding="@dimen/padding_small"
                    android:layout_marginStart="@dimen/margin_small"
                    style="@style/Button.Primary" />

            </LinearLayout>

            <!-- Loading Indicator -->
            <LinearLayout
                android:id="@+id/ll_loading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/padding_large"
                android:visibility="gone">

                <ProgressBar
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:indeterminate="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Analyzing grammar and style..."
                    android:textSize="@dimen/text_size_medium"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="@dimen/margin_medium" />

            </LinearLayout>

            <!-- Results Section -->
            <LinearLayout
                android:id="@+id/ll_results_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- Results Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/margin_medium">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Suggestions"
                        android:textSize="@dimen/text_size_large"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <!-- Issue Counter Badge -->
                    <TextView
                        android:id="@+id/tv_issue_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3 Issues Found"
                        android:textSize="@dimen/text_size_small"
                        android:textColor="@color/white"
                        android:background="@drawable/badge_background"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp" />

                </LinearLayout>

                <!-- Filter Chips -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="@dimen/margin_medium">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_filters"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleSelection="false"
                        app:chipSpacingHorizontal="@dimen/margin_small">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_all"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="All (3)"
                            android:checked="true"
                            style="@style/Widget.MaterialComponents.Chip.Filter" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_grammar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Grammar (1)"
                            style="@style/Widget.MaterialComponents.Chip.Filter" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_spelling"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Spelling (1)"
                            style="@style/Widget.MaterialComponents.Chip.Filter" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_style"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Style (1)"
                            style="@style/Widget.MaterialComponents.Chip.Filter" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_punctuation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Punctuation (0)"
                            style="@style/Widget.MaterialComponents.Chip.Filter" />

                    </com.google.android.material.chip.ChipGroup>

                </HorizontalScrollView>

                <!-- Suggestions RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_suggestions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:itemCount="3"
                    tools:listitem="@layout/item_grammar_suggestion" />

            </LinearLayout>

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/ll_empty_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/padding_xlarge"
                android:visibility="gone">

                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@drawable/ic_empty_grammar"
                    android:alpha="0.5"
                    android:layout_marginBottom="@dimen/margin_medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No results yet"
                    android:textSize="@dimen/text_size_large"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="@dimen/margin_small" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enter text and click 'Check Grammar' to analyze"
                    android:textSize="@dimen/text_size_normal"
                    android:textColor="@color/text_hint"
                    android:textAlignment="center" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
