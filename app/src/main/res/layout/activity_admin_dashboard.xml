<?xml version="1.0" encoding="utf-8"?>
<!--
Admin Dashboard Layout - ScholarHub
Premium admin panel with stats from usage_logs, sessions, submissions, users
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_admin"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:titleTextColor="@color/white"
        app:navigationIcon="@drawable/ic_back"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Loading Indicator -->
    <ProgressBar
        android:id="@+id/progress_loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/toolbar_admin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ScrollView
        android:id="@+id/content_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/toolbar_admin"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ═══════════ OVERVIEW HEADER ═══════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Platform Overview"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:fontFamily="serif"
                android:layout_marginBottom="16dp" />

            <!-- Overview Stat Cards Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Total Users -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/primary_container">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TOTAL USERS"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.15"
                            android:textColor="@color/on_primary_container"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tv_total_users"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_fixed_dim" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Active Users -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/secondary_container">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ACTIVE USERS"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.15"
                            android:textColor="@color/on_secondary_container"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tv_active_users"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/secondary" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Overview Stat Cards Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="32dp">

                <!-- Total Submissions -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/surface_container_lowest">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SUBMISSIONS"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.15"
                            android:textColor="@color/on_surface_variant"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tv_total_submissions"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Active Sessions -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/surface_container_lowest">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LIVE SESSIONS"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.15"
                            android:textColor="@color/on_surface_variant"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tv_active_sessions"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/info" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ═══════════ USAGE LOGS SECTION ═══════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Usage Logs"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:fontFamily="serif"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface_container_lowest"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Log Stats Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Requests"
                                android:textSize="11sp"
                                android:textColor="@color/text_hint" />
                            <TextView
                                android:id="@+id/tv_total_requests"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/divider" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Avg Response"
                                android:textSize="11sp"
                                android:textColor="@color/text_hint" />
                            <TextView
                                android:id="@+id/tv_avg_response_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="— ms"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/divider" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Error Rate"
                                android:textSize="11sp"
                                android:textColor="@color/text_hint" />
                            <TextView
                                android:id="@+id/tv_error_rate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="— %"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="@color/error" />
                        </LinearLayout>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/outline_variant"
                        android:layout_marginBottom="12dp" />

                    <!-- Top Endpoints -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOP ENDPOINTS"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15"
                        android:textColor="@color/text_hint"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:id="@+id/ll_top_endpoints"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Recent Logs -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RECENT API CALLS"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:textColor="@color/text_hint"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/ll_recent_logs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="32dp" />

            <!-- ═══════════ SESSIONS SECTION ═══════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sessions"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:fontFamily="serif"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface_container_lowest"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Sessions"
                            android:textSize="11sp"
                            android:textColor="@color/text_hint" />
                        <TextView
                            android:id="@+id/tv_total_sessions"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/divider" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Revoked"
                            android:textSize="11sp"
                            android:textColor="@color/text_hint" />
                        <TextView
                            android:id="@+id/tv_revoked_sessions"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/error" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RECENT SESSIONS"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:textColor="@color/text_hint"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/ll_recent_sessions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="32dp" />

            <!-- ═══════════ SUBMISSIONS SECTION ═══════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Submissions"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:fontFamily="serif"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface_container_lowest"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total"
                                android:textSize="11sp"
                                android:textColor="@color/text_hint" />
                            <TextView
                                android:id="@+id/tv_submissions_total"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/divider" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Completed"
                                android:textSize="11sp"
                                android:textColor="@color/text_hint" />
                            <TextView
                                android:id="@+id/tv_completed_submissions"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="@color/success" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/divider" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pending"
                                android:textSize="11sp"
                                android:textColor="@color/text_hint" />
                            <TextView
                                android:id="@+id/tv_pending_submissions"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="@color/warning" />
                        </LinearLayout>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/outline_variant"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BY FEATURE TYPE"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15"
                        android:textColor="@color/text_hint"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:id="@+id/ll_feature_breakdown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RECENT SUBMISSIONS"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:textColor="@color/text_hint"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/ll_recent_admin_submissions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="32dp" />

            <!-- ═══════════ USERS SECTION ═══════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Users"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:fontFamily="serif"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/ll_recent_users"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="32dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
