<?xml version="1.0" encoding="utf-8"?>
<!--
Paper Review Screen - ScholarHub
Integrity & Peer Review with bento grid, verdict card, strengths/weaknesses, and editorial styling
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    tools:context=".PaperReviewActivity">

    <!-- TopAppBar - Frosted Glass -->
    <FrameLayout
        android:id="@+id/toolbar_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:elevation="2dp"
        android:background="@color/surface_container_lowest">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/toolbar_height"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/padding_medium"
                android:paddingEnd="@dimen/padding_medium">

                <ImageView
                    android:layout_width="@dimen/icon_small"
                    android:layout_height="@dimen/icon_small"
                    android:src="@drawable/ic_review"
                    android:tint="@color/primary_container"
                    android:layout_marginEnd="@dimen/margin_small" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ScholarHub"
                    android:textSize="20sp"
                    android:textStyle="bold|italic"
                    android:textColor="@color/primary_container"
                    android:fontFamily="serif" />

                <ImageView
                    android:layout_width="@dimen/icon_small"
                    android:layout_height="@dimen/icon_small"
                    android:src="@drawable/ic_users"
                    android:tint="@color/primary_container" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/surface_container_high" />

        </LinearLayout>
    </FrameLayout>

    <!-- Hidden toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:navigationIcon="@drawable/ic_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/toolbar_container"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_medium"
            android:paddingBottom="100dp">

            <!-- Editorial Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/margin_large">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="QUALITY ASSESSMENT"
                    style="@style/Text.Label.Upper"
                    android:textColor="@color/primary"
                    android:layout_marginBottom="@dimen/margin_small" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Integrity &amp; Peer Review"
                    android:textSize="@dimen/text_size_headline"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:fontFamily="serif" />

            </LinearLayout>

            <!-- Upload Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_upload"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/surface_container_lowest"
                android:layout_marginBottom="@dimen/margin_medium">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_large"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Upload Research Paper"
                        android:textSize="@dimen/text_size_large"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:fontFamily="serif"
                        android:layout_marginBottom="@dimen/margin_small" />

                    <TextView
                        android:textColor="@color/on_surface_variant"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/margin_medium" />

                    <include
                        android:id="@+id/model_selector"
                        layout="@layout/layout_model_selector"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/margin_medium" />

                    <Button
                        android:id="@+id/btn_upload_paper"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Select PDF File"
                        android:drawableStart="@drawable/ic_pdf"
                        android:drawablePadding="@dimen/padding_small"
                        style="@style/Button.Primary" />

                    <!-- File Info -->
                    <LinearLayout
                        android:id="@+id/ll_file_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_file_info"
                        android:padding="@dimen/padding_medium"
                        android:layout_marginTop="@dimen/margin_medium"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_document"
                            android:tint="@color/primary"
                            android:layout_marginEnd="@dimen/margin_small" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_file_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="research_paper.pdf"
                                android:textSize="@dimen/text_size_medium"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:id="@+id/tv_file_size"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2.5 MB"
                                android:textSize="@dimen/text_size_small"
                                android:textColor="@color/on_surface_variant"
                                tools:ignore="HardcodedText" />

                        </LinearLayout>

                        <ImageView
                            android:id="@+id/iv_remove_file"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_close"
                            android:tint="@color/outline"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>

                    <Button
                        android:id="@+id/btn_review_paper"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Start Review"
                        android:drawableStart="@drawable/ic_review_start"
                        android:drawablePadding="@dimen/padding_small"
                        android:layout_marginTop="@dimen/margin_medium"
                        android:visibility="gone"
                        style="@style/Button.Primary" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Progress Section -->
            <LinearLayout
                android:id="@+id/ll_review_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation"
                    android:layout_marginBottom="@dimen/margin_medium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/padding_large"
                        android:gravity="center">

                        <ProgressBar
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:indeterminate="true" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Reviewing your paper..."
                            android:textSize="@dimen/text_size_large"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface"
                            android:fontFamily="serif"
                            android:layout_marginTop="@dimen/margin_large"
                            android:layout_marginBottom="@dimen/margin_small" />

                        <TextView
                            android:id="@+id/tv_review_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Analyzing structure and content..."
                            android:textSize="@dimen/text_size_normal"
                            android:textColor="@color/on_surface_variant"
                            android:textAlignment="center" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Results Section -->
            <LinearLayout
                android:id="@+id/ll_review_results"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Overall Score + Verdict Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:layout_marginBottom="@dimen/margin_medium">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Review Insights"
                        android:textSize="@dimen/text_size_xlarge"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:fontFamily="serif" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom">

                        <TextView
                            android:id="@+id/tv_overall_score"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="8.5"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:fontFamily="serif"
                            tools:ignore="HardcodedText" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="/10"
                            android:textSize="@dimen/text_size_normal"
                            android:textColor="@color/outline" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Peer Verdict Card (Gradient) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation"
                    android:layout_marginBottom="@dimen/margin_medium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/gradient_card"
                        android:padding="@dimen/padding_large">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PEER VERDICT"
                            android:textSize="9sp"
                            android:textAllCaps="true"
                            android:textStyle="bold"
                            android:letterSpacing="0.2"
                            android:textColor="@color/white"
                            android:alpha="0.7"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tv_score_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Accept with Minor Revision"
                            android:textSize="@dimen/text_size_xlarge"
                            android:textStyle="bold|italic"
                            android:textColor="@color/white"
                            android:fontFamily="serif"
                            android:layout_marginBottom="@dimen/margin_small"
                            tools:ignore="HardcodedText" />

                        <TextView
                            android:id="@+id/tv_verdict"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="The methodology is sound, but data visualization requires higher fidelity before print."
                            android:textSize="@dimen/text_size_small"
                            android:textColor="@color/white"
                            android:alpha="0.8"
                            android:lineSpacingExtra="4dp"
                            tools:ignore="HardcodedText" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Strengths & Weaknesses Bento -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/margin_medium">

                    <!-- Strengths -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="@dimen/margin_small"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/surface_container_lowest"
                        app:strokeColor="@color/outline_variant"
                        app:strokeWidth="0.5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/padding_large">

                            <FrameLayout
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_tip_box"
                                android:layout_marginBottom="@dimen/margin_small">

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_check_circle"
                                    android:tint="@color/secondary" />

                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="STRENGTHS"
                                style="@style/Text.Label.Upper"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tv_strengths"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Novel approach to market volatility models."
                                android:textSize="@dimen/text_size_small"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface"
                                android:lineSpacingExtra="4dp"
                                tools:ignore="HardcodedText" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Weaknesses -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/margin_small"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/surface_container_lowest"
                        app:strokeColor="@color/outline_variant"
                        app:strokeWidth="0.5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/padding_large">

                            <FrameLayout
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginBottom="@dimen/margin_small">

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_warning_circle"
                                    android:tint="@color/on_tertiary_container" />

                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="WEAKNESSES"
                                style="@style/Text.Label.Upper"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tv_weaknesses"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Sample size in pilot study is restricted."
                                android:textSize="@dimen/text_size_small"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface"
                                android:lineSpacingExtra="4dp"
                                tools:ignore="HardcodedText" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Suggestions Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/surface_container_low"
                    android:layout_marginBottom="@dimen/margin_medium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/padding_large">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RECOMMENDATIONS"
                            style="@style/Text.Label.Upper"
                            android:layout_marginBottom="@dimen/margin_small" />

                        <TextView
                            android:id="@+id/tv_suggestions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="1. Add a dedicated limitations section\n2. Expand the conclusion with future directions\n3. Improve figure quality and captions"
                            android:textSize="@dimen/text_size_normal"
                            android:textColor="@color/on_surface"
                            android:lineSpacingExtra="6dp"
                            tools:ignore="HardcodedText" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- CTA Buttons -->
                <Button
                    android:id="@+id/btn_save_review"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Generate Full Report"
                    android:drawableStart="@drawable/ic_download"
                    android:drawablePadding="@dimen/padding_small"
                    android:layout_marginBottom="@dimen/margin_medium"
                    style="@style/Button.Primary" />

                <Button
                    android:id="@+id/btn_new_review"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="View Suggested Edits"
                    android:drawableStart="@drawable/ic_review_start"
                    android:drawablePadding="@dimen/padding_small"
                    style="@style/Button.Secondary" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>