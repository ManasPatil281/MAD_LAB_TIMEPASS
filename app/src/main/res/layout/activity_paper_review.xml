<?xml version="1.0" encoding="utf-8"?>
<!--
Paper Review Screen - ScholarMate
Comprehensive paper review with detailed analysis sections
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_secondary"
    tools:context=".PaperReviewActivity">

    <!-- App Bar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        android:elevation="4dp"
        app:title="Paper Reviewer"
        app:titleTextColor="@color/white"
        app:navigationIcon="@drawable/ic_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_medium">

            <!-- Upload Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_upload"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                android:layout_marginBottom="@dimen/margin_medium">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_large"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Upload Research Paper"
                        android:textSize="@dimen/text_size_large"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="@dimen/margin_small" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PDF format • Max 10MB"
                        android:textSize="@dimen/text_size_small"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="@dimen/margin_large" />

                    <Button
                        android:id="@+id/btn_upload_paper"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Select PDF File"
                        android:drawableStart="@drawable/ic_pdf"
                        android:drawablePadding="@dimen/padding_small"
                        style="@style/Button.Primary" />

                    <!-- File Info (hidden until file selected) -->
                    <LinearLayout
                        android:id="@+id/ll_file_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_file_info"
                        android:padding="@dimen/padding_medium"
                        android:layout_marginTop="@dimen/margin_medium"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_document"
                            android:layout_marginEnd="@dimen/margin_small" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_file_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="research_paper.pdf"
                                android:textSize="@dimen/text_size_medium"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:id="@+id/tv_file_size"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2.5 MB"
                                android:textSize="@dimen/text_size_small"
                                android:textColor="@color/text_secondary"
                                tools:ignore="HardcodedText" />

                        </LinearLayout>

                        <ImageView
                            android:id="@+id/iv_remove_file"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_close"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>

                    <Button
                        android:id="@+id/btn_review_paper"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Start Review"
                        android:drawableStart="@drawable/ic_review_start"
                        android:drawablePadding="@dimen/padding_small"
                        android:layout_marginTop="@dimen/margin_medium"
                        android:visibility="gone"
                        style="@style/Button.Primary" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Progress Section -->
            <LinearLayout
                android:id="@+id/ll_review_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation"
                    android:layout_marginBottom="@dimen/margin_medium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/padding_large"
                        android:gravity="center">

                        <ProgressBar
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:indeterminate="true" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Reviewing your paper..."
                            android:textSize="@dimen/text_size_large"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginTop="@dimen/margin_large"
                            android:layout_marginBottom="@dimen/margin_small" />

                        <TextView
                            android:id="@+id/tv_review_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Analyzing structure and content..."
                            android:textSize="@dimen/text_size_normal"
                            android:textColor="@color/text_secondary"
                            android:textAlignment="center" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Results Section -->
            <LinearLayout
                android:id="@+id/ll_review_results"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Overall Score Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation"
                    app:cardBackgroundColor="@drawable/gradient_score"
                    android:layout_marginBottom="@dimen/margin_medium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/padding_large"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Overall Score"
                            android:textSize="@dimen/text_size_medium"
                            android:textColor="@color/white"
                            android:alpha="0.9"
                            android:layout_marginBottom="@dimen/margin_small" />

                        <TextView
                            android:id="@+id/tv_overall_score"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="8.5/10"
                            android:textSize="48sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            tools:ignore="HardcodedText" />

                        <TextView
                            android:id="@+id/tv_score_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Excellent Work"
                            android:textSize="@dimen/text_size_large"
                            android:textColor="@color/white"
                            android:layout_marginTop="@dimen/margin_small"
                            tools:ignore="HardcodedText" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Strengths Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation"
                    android:layout_marginBottom="@dimen/margin_medium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/padding_large">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="@dimen/margin_medium">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_check_circle"
                                android:tint="@color/success"
                                android:layout_marginEnd="@dimen/margin_small" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Strengths"
                                android:textSize="@dimen/text_size_large"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_strengths"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="• Well-structured methodology\n• Clear research objectives\n• Comprehensive literature review\n• Strong data analysis"
                            android:textSize="@dimen/text_size_normal"
                            android:textColor="@color/text_primary"
                            android:lineSpacingExtra="6dp"
                            tools:ignore="HardcodedText" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Weaknesses Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation"
                    android:layout_marginBottom="@dimen/margin_medium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/padding_large">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="@dimen/margin_medium">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_warning_circle"
                                android:tint="@color/warning"
                                android:layout_marginEnd="@dimen/margin_small" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Areas for Improvement"
                                android:textSize="@dimen/text_size_large"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_weaknesses"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="• Limited discussion of limitations\n• Could expand on future research\n• Some figures need better captions"
                            android:textSize="@dimen/text_size_normal"
                            android:textColor="@color/text_primary"
                            android:lineSpacingExtra="6dp"
                            tools:ignore="HardcodedText" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Suggestions Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation"
                    android:layout_marginBottom="@dimen/margin_medium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/padding_large">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="@dimen/margin_medium">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_lightbulb"
                                android:tint="@color/info"
                                android:layout_marginEnd="@dimen/margin_small" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Recommendations"
                                android:textSize="@dimen/text_size_large"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_suggestions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="1. Add a dedicated limitations section\n2. Expand the conclusion with future directions\n3. Improve figure quality and captions\n4. Consider adding more recent citations"
                            android:textSize="@dimen/text_size_normal"
                            android:textColor="@color/text_primary"
                            android:lineSpacingExtra="6dp"
                            tools:ignore="HardcodedText" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Final Verdict Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation"
                    android:layout_marginBottom="@dimen/margin_medium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/padding_large">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Final Verdict"
                            android:textSize="@dimen/text_size_large"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="@dimen/margin_medium" />

                        <TextView
                            android:id="@+id/tv_verdict"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="This is a well-executed research paper with strong methodology and analysis. With minor revisions addressing the identified weaknesses, this paper will be publication-ready."
                            android:textSize="@dimen/text_size_normal"
                            android:textColor="@color/text_primary"
                            android:lineSpacingExtra="4dp"
                            tools:ignore="HardcodedText" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Action Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn_save_review"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Save PDF"
                        android:drawableStart="@drawable/ic_download"
                        android:drawablePadding="@dimen/padding_small"
                        android:layout_marginEnd="@dimen/margin_small"
                        style="@style/Button.Primary" />

                    <Button
                        android:id="@+id/btn_new_review"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="New Review"
                        android:drawableStart="@drawable/ic_refresh"
                        android:drawablePadding="@dimen/padding_small"
                        android:layout_marginStart="@dimen/margin_small"
                        style="@style/Button.Secondary" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>