<?xml version="1.0" encoding="utf-8"?>
<!--
Matched source item - ScholarHub editorial style
Flat card with source name, URL, and percentage
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_tool_card"
    android:padding="@dimen/padding_medium"
    android:layout_marginBottom="@dimen/margin_small">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_source_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Journal of Digital Economy"
            android:textSize="@dimen/text_size_normal"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_source_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="https://jde.org/archive/2023/102"
            android:textSize="@dimen/text_size_tiny"
            android:textColor="@color/on_surface_variant"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <TextView
        android:id="@+id/tv_similarity_percentage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="3.2%"
        android:textSize="@dimen/text_size_small"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:layout_marginStart="@dimen/margin_medium" />

    <!-- Hidden progress bar (kept for Java compatibility) -->
    <ProgressBar
        android:id="@+id/progress_similarity"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:max="100"
        android:progress="3"
        android:visibility="gone" />

    <!-- Hidden icon for compatibility -->
    <ImageView
        android:id="@+id/iv_source_icon"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

</LinearLayout>
