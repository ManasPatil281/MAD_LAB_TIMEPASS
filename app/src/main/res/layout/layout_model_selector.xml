<?xml version="1.0" encoding="utf-8"?>
<!--
Model Selector - ScholarHub Editorial Style
Toggle group for AI model selection with uppercase label
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AI MODEL"
        android:textSize="10sp"
        android:textAllCaps="true"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:textColor="@color/outline"
        android:layout_marginBottom="@dimen/margin_small"/>

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/model_toggle_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        app:checkedButton="@+id/btn_model_fast"
        app:selectionRequired="true">

        <Button
            android:id="@+id/btn_model_fast"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Llama 3 (Fast)"
            android:textSize="12sp"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btn_model_advanced"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="GPT Oss (Advanced)"
            android:textSize="12sp"
            android:textAllCaps="false" />

    </com.google.android.material.button.MaterialButtonToggleGroup>

</LinearLayout>
